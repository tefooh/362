{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@ee/*": [
        "../../ee/desktop/*"
      ]
    },
    "types": ["@tauri-apps/api"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src-tauri",
    "scripts",
    "e2e",
    "vitest.config.ts",
    "vitest.setup.ts",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}