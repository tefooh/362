{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project 362 - Development",
  "identifier": "screenpi.pe.dev",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../out",
    "devUrl": "http://127.0.0.1:1480"
  },
  "bundle": {
    "active": true,
    "publisher": "Project 362",
    "category": "DeveloperTool",
    "shortDescription": "Your days on screen, reported like news",
    "longDescription": "Project 362 turns your screen activity into a daily newspaper edition. 100% local. You own your data.",
    "copyright": "",
    "targets": [
      "app",
      "dmg",
      "deb",
      "appimage",
      "nsis"
    ],
    "externalBin": [],
    "icon": [
      "icons/dev/32x32.png",
      "icons/dev/128x128.png",
      "icons/dev/128x128@2x.png",
      "icons/dev/256x256.png",
      "icons/dev/512x512.png",
      "icons/dev/1024x1024.png",
      "icons/dev/icon.icns",
      "icons/dev/icon.ico",
      "icons/project-362-logo-tray-failed.png",
      "icons/project-362-logo-tray-black.png"
    ],
    "resources": [
      "assets/*",
      "PermissionFlow_PermissionFlow.bundle"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "project-362"
        ]
      },
      "mobile": [
        {
          "host": "project-362.com",
          "pathPrefix": [
            "/auth"
          ]
        },
        {
          "host": "project-362.com",
          "pathPrefix": [
            "/stripe-connect"
          ]
        },
        {
          "host": "project-362.com",
          "pathPrefix": [
            "/purchase-successful"
          ]
        },
        {
          "host": "project-362.com",
          "pathPrefix": [
            "/settings"
          ]
        },
        {
          "host": "project-362.com",
          "pathPrefix": [
            "/changelog"
          ]
        },
        {
          "host": "project-362.com",
          "pathPrefix": [
            "/onboarding"
          ]
        },
        {
          "host": "project-362.com",
          "pathPrefix": [
            "/status"
          ]
        }
      ]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "id": "project_362_main",
      "iconPath": "assets/project-362-logo-tray-white.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true
    },
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$HOME/.project-362/**"
        ]
      },
      "csp": null
    },
    "macOSPrivateApi": true
  }
}
